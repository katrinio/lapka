# Скопируй в .env и заполни значения.

# Секретный ключ для подписи сессионных cookie.
# Любая случайная строка: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# Пароль для входа в приложение.
ECHO_PASSWORD=

# Имя пользователя (отображается в интерфейсе).
# По умолчанию: katrin
ECHO_USERNAME=katrin

# URL базы данных.
# По умолчанию: sqlite:///echo.db в корне проекта.
# DATABASE_URL=sqlite:///echo.db

# Окружение. Влияет на флаг secure у cookie.
# Установи production на проде.
# ENVIRONMENT=production
